# Group chat the 9am brief posts to. Get it by messaging /chatid to the bot
# from inside the group, then copy the number it replies with.
TELEGRAM_GROUP_CHAT_ID=

# Personal DM chat ID for cron-failure alerts. Get it by DMing /chatid to
# the bot directly (not in the group).
ADMIN_CHAT_ID=

# Shared secret Vercel Cron sends as "Authorization: Bearer <value>".
# Generate with: openssl rand -hex 24
CRON_SECRET=

# Set after first deploy: https://<your-project>.vercel.app
PUBLIC_URL=
